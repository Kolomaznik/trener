# =============================================================================
# GlitchTip — Railway.app environment variables
# =============================================================================
# Copy these into the Railway Variables panel of BOTH the web service AND the
# worker service. Railway "Shared Variables" (service → Variables → Share)
# lets you define them once and reference them from both services.
#
# NEVER commit a .env file with real values — .env is in .gitignore.
# Use this file as a checklist when configuring Railway.
# =============================================================================

# -----------------------------------------------------------------------------
# Security — REQUIRED
# -----------------------------------------------------------------------------
# Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(50))'
# Must be at least 50 characters long and kept secret.
SECRET_KEY=change_me_to_a_long_random_string_of_at_least_50_chars

# -----------------------------------------------------------------------------
# Database + cache — REQUIRED
# -----------------------------------------------------------------------------
# Railway injects these automatically when you add the Postgres and Redis
# plugins to the project. In the Variables panel use the reference syntax:
#
#   DATABASE_URL = ${{Postgres.DATABASE_URL}}
#   REDIS_URL    = ${{Redis.REDIS_URL}}
#
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://host:6379

# -----------------------------------------------------------------------------
# Public URL — REQUIRED
# -----------------------------------------------------------------------------
# The URL where GlitchTip is reachable from the internet.
# Set this AFTER Railway assigns a domain to the web service.
# Example: https://glitchtip-production.up.railway.app
# Used for generating DSNs, OAuth callbacks, and email links.
GLITCHTIP_DOMAIN=https://your-glitchtip-domain.up.railway.app

# -----------------------------------------------------------------------------
# Email — strongly recommended
# -----------------------------------------------------------------------------
# Without email, GlitchTip works but cannot send alert notifications or
# password-reset messages.
#
# Format: smtp://user:password@host:port
#         smtp+ssl://user:password@host:465
#         smtp+tls://user:password@host:587
#         consolemail://   ← prints to stdout (useful for testing)
#
# Examples:
#   Mailgun:  smtp://apikey:<MAILGUN_KEY>@smtp.mailgun.org:587
#   Sendgrid: smtp://apikey:<SENDGRID_KEY>@smtp.sendgrid.net:587
#   Gmail:    smtp+tls://you%40gmail.com:<APP_PASSWORD>@smtp.gmail.com:587
#
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=noreply@your-glitchtip-domain.up.railway.app

# -----------------------------------------------------------------------------
# Initial admin account — REQUIRED on first deploy, remove after
# -----------------------------------------------------------------------------
# GlitchTip's web Dockerfile runs `manage.py createsuperuser --noinput`
# on startup using these variables. The command is idempotent (fails silently
# if the user already exists). Remove these variables after the first
# successful deploy for security.
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme_use_a_strong_password

# -----------------------------------------------------------------------------
# Registration
# -----------------------------------------------------------------------------
# Set to False to prevent public sign-ups (recommended for private teams).
# Set to True only if you want anyone to be able to create an account.
ENABLE_OPEN_USER_REGISTRATION=False

# -----------------------------------------------------------------------------
# Performance tuning
# -----------------------------------------------------------------------------
# Number of gunicorn worker processes (web service only).
WEB_CONCURRENCY=2

# Number of Celery worker processes (worker service only).
CELERY_WORKER_CONCURRENCY=2

# Days to keep error events. Older events are deleted by the periodic task.
# Decrease if you run out of Postgres storage on Railway's free tier.
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90

# -----------------------------------------------------------------------------
# Optional: HTTPS enforcement
# -----------------------------------------------------------------------------
# Set to True in production so GlitchTip generates https:// DSNs.
# Railway terminates TLS for you, so the app itself runs on plain HTTP.
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_HOST=True
