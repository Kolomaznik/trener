# =============================================================================
# Trener backend konfigurace
# =============================================================================
# Backend cte tento .env soubor pres pydantic-settings (BACKEND/config.py).
# Tento soubor je sablona — zkopiruj ho do `.env` (`cp .env.example .env`)
# a vypln nize uvedene hodnoty. Soubor `.env` je v .gitignore, nikdy ho
# necommituj — `MONGO_URI` obsahuje heslo k databazi.
# =============================================================================

# Nazev aplikace, pouzivany v `FastAPI(title=...)` a v `/` endpointu.
APP_NAME=trener-backend

# JSON pole povolenych originu pro CORS. Pridej sem URL frontendu.
CORS_ORIGINS=["http://localhost:5173"]

# -----------------------------------------------------------------------------
# MongoDB pripojeni (MONGO_URI, MONGO_DATABASE)
# -----------------------------------------------------------------------------
# Backend pouziva MongoDB pro ulozeni uzivatelu (kolekce `users`).
# Doporuceny zpusob je MongoDB Atlas (free tier M0 staci pro vyvoj),
# alternativne lokalni MongoDB (`mongodb://localhost:27017`).
#
# Postup pro MongoDB Atlas (cloud, mongodb.com):
#
# 1) Zaloz si ucet na  https://www.mongodb.com/cloud/atlas/register
#    (jde to i pres Google login).
#
# 2) Vytvor cluster:
#    - Po prihlaseni klikni "Build a Database".
#    - Zvol tier "M0 FREE" (sdileny, 512 MB, zdarma navzdy).
#    - Provider: kterykoliv (AWS / GCP / Azure), region nejblizsi tobe.
#    - Cluster name: napr. "trener-dev". Klikni "Create Deployment".
#    - Vytvoreni trva ~3 minuty.
#
# 3) Vytvor databazoveho uzivatele (jine udaje nez login do Atlasu!):
#    - Pri prvnim cluster setupu te Atlas vyzve k zalozeni "database user".
#    - Username: napr. "trener-app". Heslo: vygeneruj silne, ULOZ SI HO.
#    - Authentication method: "Password".
#    - Klikni "Create User".
#    - (Pozdeji editovatelne v menu "Database Access".)
#
# 4) Povol pristup ze sve IP:
#    - V setupu te Atlas vyzve k pridani IP do "Network Access".
#    - Pro vyvoj klikni "Add My Current IP Address".
#    - Pro provoz odkudkoliv (mene bezpecne) pridej `0.0.0.0/0`.
#    - (Pozdeji editovatelne v menu "Network Access".)
#
# 5) Ziskej connection string:
#    - V menu "Database" klikni u sveho clusteru na "Connect".
#    - Zvol "Drivers" -> "Python" -> verze "3.12 or later".
#    - Zkopiruj zobrazeny URI, vypada takto:
#      mongodb+srv://trener-app:<db_password>@trener-dev.abc12.mongodb.net/?retryWrites=true&w=majority&appName=trener-dev
#    - Nahrad `<db_password>` skutecnym heslem z kroku 3.
#      (Pozor: heslo URL-encode pokud obsahuje speci. znaky `@:/?#`.)
#    - Vloz vysledek do MONGO_URI nize.
#
# 6) MONGO_DATABASE je nazev DB, kterou backend pouziva. Atlas DB sam
#    vytvori pri prvnim zapisu, nemusis ji predem zakladat.
#
# Tip — overeni pripojeni:
#    python -c "from pymongo import MongoClient; \
#               c = MongoClient('TVUJ_MONGO_URI', serverSelectionTimeoutMS=3000); \
#               print(c.admin.command('ping'))"
#    Pokud vrati `{'ok': 1.0}`, pripojeni funguje.
#
# Reseni problemu:
#    - "ServerSelectionTimeoutError": IP neni v "Network Access" allowlistu.
#    - "Authentication failed": spatne heslo nebo username (krok 3).
#    - "ENOTFOUND" / DNS error: zkontroluj copy-paste cluster URL.
# -----------------------------------------------------------------------------

MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=trener

# -----------------------------------------------------------------------------
# Google OAuth — verifikace access tokenu
# -----------------------------------------------------------------------------
# Backend pri requestu na chranene endpointy vola Google userinfo
# endpoint, aby overil access token z hlavicky `Authorization: Bearer ...`
# a ziskal email uzivatele. Default funguje out-of-the-box, menit jen
# pokud testujes proti mocku.
#
# Pozn.: na backend NEPATRI VITE_GOOGLE_CLIENT_ID — to je ciste frontendova
# OAuth konfigurace (viz FRONTEND/.env.example).
# -----------------------------------------------------------------------------

GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo

# -----------------------------------------------------------------------------
# CORS — povolene originy (CORS_ORIGINS, CORS_ORIGIN_REGEX)
# -----------------------------------------------------------------------------
# JSON pole URL, ze kterych smi prohlizec volat API.
# Pri lokalnim vyvoji staci vychozi hodnota.
# Pri nasazeni na Railway.app nastav na URL frontendu, napr.:
#   CORS_ORIGINS=["https://trener-frontend.up.railway.app"]
# Pokud mas vice prostredi (staging + produkce) oddel je carkou uvnitr pole:
#   CORS_ORIGINS=["https://staging.example.com","https://example.com"]
#
# Alternativne (nebo navic) lze pouzit CORS_ORIGIN_REGEX — regex vzor pro
# povolene originy. Hodne se hodi na Railway, kde chces povolit vsechny
# frontend subdomeny bez znamosti presneho URL:
#   CORS_ORIGIN_REGEX=^https://[^.]+\.up\.railway\.app$
# -----------------------------------------------------------------------------

CORS_ORIGINS=["http://localhost:5173"]

# Volitelne: regex vzor pro povolene CORS originy.
# Pouzij pro Railway.app nasazeni, kde chces povolit vsechny frontend subdomeny:
#   CORS_ORIGIN_REGEX=^https://[^.]+\.up\.railway\.app$
# Pokud neni nastaveno, pouziji se jen originy z CORS_ORIGINS.
CORS_ORIGIN_REGEX=

# -----------------------------------------------------------------------------
# Sentry — sledovani chyb a vykonu backendu
# -----------------------------------------------------------------------------
# Backend pouziva Sentry SDK pro zachytavani neosetrených výjimek a sledování
# výkonu jednotlivých HTTP požadavků.
#
# Jak získat DSN:
#   1. Prihlaste se na https://sentry.io/ a vytvořte nový projekt (Python/FastAPI).
#   2. V nastavení projektu prejdi na "Settings" -> "Client Keys (DSN)".
#   3. Zkopiruj hodnotu "DSN" a vloz ji sem.
#
# Pokud je promenna prazdna nebo neni nastavena, Sentry se neinicializuje
# (bezpecne pro lokalni vyvoj).
# -----------------------------------------------------------------------------

SENTRY_DSN=

# Podíl zachycených transakci pro sledování výkonu (0.0–1.0).
# Pro produkci doporučujeme nižší hodnotu (napr. 0.1 = 10 %).
# Pokud neni nastaveno, použije se výchozí 0.1.
SENTRY_TRACES_SAMPLE_RATE=0.1
