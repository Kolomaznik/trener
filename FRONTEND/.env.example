# =============================================================================
# Google OAuth konfigurace pro frontend
# =============================================================================
# Frontend pouziva Google OAuth 2.0 (Implicit Flow) k prihlaseni uzivatele.
# Tento soubor je sablona — zkopiruj ho do `.env` (`cp .env.example .env`)
# a vypln nize uvedene hodnoty. Soubor `.env` je v .gitignore, nikdy ho
# necommituj.
#
# -----------------------------------------------------------------------------
# DULEZITE — Railway.app nasazeni (Docker build-args)
# -----------------------------------------------------------------------------
# Vite zapece VITE_* promenne do JS bundle pri `npm run build`.
# Proto je nelze nastavit az za behu kontejneru — musi byt dostupne
# jiz behem Docker build faze.
#
# Railway tyto promenne predava automaticky jako Docker build-args,
# pokud je mas nastavene v panelu Variables pro dany service.
# Dockerfile je deklaruje pres `ARG`, takze zadna dalsi konfigurace
# na strane Railway neni potreba.
#
# Postup pro Railway:
#   1. Otevri Railway service pro frontend.
#   2. Prejdi do zalozky "Variables".
#   3. Pridej nasledujici promenne s hodnotami pro produkcni prostredi:
#        VITE_GOOGLE_CLIENT_ID       = <tvoje Client ID z GCP>
#        VITE_GOOGLE_REDIRECT_URI    = https://<tvoje-frontend-domena>.up.railway.app
#        VITE_GOOGLE_OAUTH_SCOPE     = openid email profile
#        VITE_GOOGLE_AUTH_URL        = https://accounts.google.com/o/oauth2/v2/auth
#   4. Take nastav:
#        BACKEND_URL = https://<tvoje-backend-domena>.up.railway.app
#      (BACKEND_URL pouziva nginx proxy — neni to VITE_ promenna,
#       je dostupna za behu kontejneru.)
#        VITE_API_BASE_URL = https://<tvoje-backend-domena>.up.railway.app/api
#      (VITE_API_BASE_URL je build-time promenna; pokud ji nastavis, axios
#       posila requesty primo na tento URL misto pres nginx proxy /api.
#       Pokud ji nechas prazdnou, pouzije se vychozi /api proxy.)
#   5. Redeploy service — Railway spusti novy Docker build s predanymi ARG.
#
# -----------------------------------------------------------------------------
# Postup ziskani VITE_GOOGLE_CLIENT_ID
# -----------------------------------------------------------------------------
# 1) Otevri Google Cloud Console:  https://console.cloud.google.com/
#
# 2) Vytvor (nebo vyber) projekt:
#    - Vlevo nahore klikni na seznam projektu -> "New Project".
#    - Zadej nazev (napr. "trener-dev") a klikni "Create".
#
# 3) Nastav OAuth consent screen (jednou per projekt):
#    - Menu: "APIs & Services" -> "OAuth consent screen".
#    - User Type: "External" (pokud nemas Google Workspace) -> "Create".
#    - Vypln App name, User support email, Developer contact email.
#    - Scopes: pridej `openid`, `email`, `profile`.
#    - Test users: pridej svoji Google adresu (jinak se neprihlasis,
#      dokud je app v rezimu "Testing").
#
# 4) Vytvor OAuth 2.0 Client ID:
#    - Menu: "APIs & Services" -> "Credentials" -> "Create Credentials"
#      -> "OAuth client ID".
#    - Application type: "Web application".
#    - Name: libovolny (napr. "trener-frontend-local").
#    - Authorized JavaScript origins:  http://localhost:5173
#    - Authorized redirect URIs:       http://localhost:5173
#      (musi se PRESNE shodovat s VITE_GOOGLE_REDIRECT_URI nize, vcetne
#      portu a bez koncoveho lomitka.)
#    - Klikni "Create" -> zobrazi se "Client ID" a "Client secret".
#      Zkopiruj "Client ID" (konci na `.apps.googleusercontent.com`)
#      do VITE_GOOGLE_CLIENT_ID. Client secret tady NEPOTREBUJES
#      (Implicit Flow bezi v prohlizeci).
#
# 5) Pri nasazeni na jinou doménu pridej do "Authorized JavaScript origins"
#    a "Authorized redirect URIs" produkcni URL a aktualizuj .env na
#    danem prostredi.
#
# 6) Po zmene .env restartuj `npm run dev` (Vite cte env jen pri startu).
#
# Tip: Pokud po prihlaseni dostanes "redirect_uri_mismatch", nesouhlasi
# VITE_GOOGLE_REDIRECT_URI s tim, co mas v Google Cloud Console.
# =============================================================================

# OAuth Client ID z Google Cloud Console (kroky 1-4 vyse).
VITE_GOOGLE_CLIENT_ID=758538112964-5muol3jovgcudr6n8admkaa5g9lkhroq.apps.googleusercontent.com

# URL, kam Google vrati uzivatele s access tokenem v URL hash.
# Musi byt presne stejne jako "Authorized redirect URI" v GCP.
# Pro Railway nastav na: https://<tvoje-frontend-domena>.up.railway.app
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173

# Pozadovane OAuth scopes (mezerou oddelene). Pro nacteni e-mailu staci
# `openid email profile`.
VITE_GOOGLE_OAUTH_SCOPE=openid email profile

# Google OAuth authorize endpoint. Menit jen pokud vis proc (napr. test).
VITE_GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth

# Volitelne: plna zakladni URL backendu, napr.
# https://<tvoje-backend-domena>.up.railway.app/api
# Pokud neni nastaveno, axios pouziva /api a requesty jdou pres nginx proxy.
# Pro lokalni vyvoj nechat prazdne (Vite proxy zajisti presmerovani na localhost:8001).
VITE_API_BASE_URL=

# =============================================================================
# GlitchTip / Sentry — sledovani chyb frontendu
# =============================================================================
# Frontend pouziva @sentry/react pro zachytavani unhandled exceptions,
# sledovani vykonu navigaci (React Router tracing) a Session Replay.
# SDK je plně kompatibilní s GlitchTip (open-source, self-hosted alternativa
# Sentry) i se sentry.io — pouze změníš DSN.
#
# Doporucujeme GlitchTip hostovany na Railway.app (viz SENTRY/README.md).
#
# Jak ziskat VITE_SENTRY_DSN z GlitchTip:
#   1. Nasad GlitchTip dle SENTRY/README.md (kroky 1–7).
#   2. Prihlaste se do GlitchTip a otevrete svuj frontend projekt.
#   3. Prejdi na "Settings" -> "Client Keys (DSN)".
#   4. Zkopiruj hodnotu "DSN" a vloz ji sem.
#      Format: https://<key>@<glitchtip-domain>/<project-id>
#
# Alternativne lze pouzit sentry.io — postup je stejny.
#
# Pokud je promenna prazdna nebo neni nastavena, monitoring se neinicializuje
# (bezpecne pro lokalni vyvoj).
#
# SENTRY_AUTH_TOKEN, SENTRY_ORG a SENTRY_PROJECT jsou potreba pouze pri
# produkčním buildu pro upload source map (citelne stack traces).
# Nastav je v Railway Variables — NIKDY je necommituj.
# =============================================================================

VITE_SENTRY_DSN=

# Podíl zachycených transakci pro sledování výkonu (0.0–1.0, výchozí 0.1).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Auth token pro upload source map (pouze build-time, neni VITE_ promenna).
# Vytvoř v GlitchTip: tvuj-projekt -> Settings -> Auth Tokens
# Alternativne: https://sentry.io/ -> User Settings -> Auth Tokens
SENTRY_AUTH_TOKEN=

# Slug organizace v Sentry (viditelny v URL: sentry.io/organizations/<org>/).
SENTRY_ORG=

# Slug projektu v Sentry (viditelny v URL projektu).
SENTRY_PROJECT=
