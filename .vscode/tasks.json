{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend FastAPI",
      "type": "shell",
      "command": "uv run fastapi dev --port 8001",
      "options": {
        "cwd": "${workspaceFolder}/BACKEND"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run Frontend Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/FRONTEND"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
